{
  "expo": {
    "name": "Vogel",
    "slug": "Vogel",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "vogel",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yenipc002.Vogel",
      "buildNumber": "1",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Vogel, Almanca telaffuz alıştırmaları için mikrofona erişmek istiyor. Konuşma kaydı cihazınızda kalır, sunucuya gönderilmez.",
        "NSSpeechRecognitionUsageDescription": "Vogel, Almanca telaffuzunuzu değerlendirmek için konuşma tanıma kullanır.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.yenipc002.Vogel",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F8FAFC",
          "dark": {
            "image": "./assets/images/splash-icon.png",
            "backgroundColor": "#0F172A"
          }
        }
      ],
      [
        "@sentry/react-native",
        {
          "organization": "SENTRY_ORG_SLUG",
          "project": "SENTRY_PROJECT_SLUG"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "21745df7-9f0a-4996-9b3f-fb5d891276a1"
      }
    }
  }
}
