# Expo — etkileşimli prompt'ları kapat (CI/Claude için)
EXPO_NO_INTERACTIVE=1

# Sentry hata izleme — sentry.io'dan alınan DSN
# Sentry → Projects → vogel → Settings → Client Keys → DSN
EXPO_PUBLIC_SENTRY_DSN=https://YOUR_KEY@oXXXXXX.ingest.sentry.io/XXXXXXX

# RevenueCat IAP — app.revenuecat.com → Project → API Keys → iOS Public SDK Key
EXPO_PUBLIC_RC_API_KEY_IOS=appl_xxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_RC_API_KEY_ANDROID=goog_xxxxxxxxxxxxxxxxxx

# Firebase — console.firebase.google.com > Proje Ayarları > Genel > Uygulama bilgileri
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google Sign-In — Firebase Console > Auth > Google provider > Web Client ID
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# app.json'daki iosUrlScheme için: GoogleService-Info.plist > REVERSED_CLIENT_ID
