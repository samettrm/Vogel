rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────────
    // Mevcut user progress (sync.ts — değişmedi)
    // ─────────────────────────────────────────────────────────────
    match /users/{uid}/data/progress {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ─────────────────────────────────────────────────────────────
    // Family-invite sistemi (Phase 1)
    //
    // Tüm yazma işlemleri Cloud Functions üzerinden yapılır
    // (server-side: capacity check, idempotency, RC entitlement
    // doğrulama). Client SADECE okuyabilir.
    // ─────────────────────────────────────────────────────────────

    // Aile dokümanı: owner + members okuyabilir
    match /families/{ownerUid} {
      allow read: if request.auth != null && (
        request.auth.uid == ownerUid
        || isMemberOfFamily(resource.data, request.auth.uid)
      );
      allow write: if false; // sadece Cloud Functions (admin SDK bypass)
    }

    // Davet kodları: kimlik doğrulanmış herhangi biri lookup yapabilir
    // (kabul akışında client kodu okuyup acceptInvite callable'a gönderir)
    match /familyInvites/{code} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Kullanıcının kendi familyRef'i: sadece kendisi okuyabilir
    // (PremiumSyncer + FamilySyncer client-side listener)
    match /users/{uid}/familyRef/{docId} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // ─────────────────────────────────────────────────────────────
    // Default deny — yukarıda eşleşmeyen her şey reddedilir
    // ─────────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

// Member listesi içinde uid aramak için helper
function isMemberOfFamily(familyData, uid) {
  return familyData.members != null
    && familyData.members.size() > 0
    && uid in familyData.members.map(m => m.uid);
}
