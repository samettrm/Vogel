{
  "cli": {
    "version": ">= 18.13.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_SENTRY_DSN": "",
        "EXPO_PUBLIC_RC_API_KEY_IOS": "",
        "EXPO_PUBLIC_RC_API_KEY_ANDROID": ""
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "language": "tr-TR",
        "appleId": "trsamet71@gmail.com",
        "ascAppId": "",
        "bundleIdentifier": "com.yenipc002.Vogel"
      }
    }
  }
}
